# Issuer of the self-issued tst* classic assets. Needed for trustline ops.
NEXT_PUBLIC_TEST_ISSUER=GDIYTKW2SS3OVYPHZJ2QOJSSKVPME5GQLRHDJNZ3OZRP6QJHAEFXTZT3

# TESTNET ONLY - powers the in-app faucet. Leave blank unless you need faucet
